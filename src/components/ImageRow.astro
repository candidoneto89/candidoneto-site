---
interface Props {
  images: string[];
  alt?: string | string[];
  zoom?: boolean;
}

const { images, alt = [], zoom = false } = Astro.props;

const getAlt = (i: number) =>
  Array.isArray(alt) ? (alt[i] ?? '') : alt;
---

<div class="image-row">
  {images.map((src, i) => (
    <div class="image-row-item">
      <img
        src={src}
        alt={getAlt(i)}
        loading="lazy"
        title={zoom ? 'zoom' : undefined}
        class={zoom ? 'zoomable' : ''}
      />
    </div>
  ))}
</div>

<style>
  .image-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    gap: 0.5rem;
    margin: 2rem 0;
  }

  .image-row-item {
    overflow: hidden;
    border-radius: var(--radius);
  }

  .image-row-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    margin: 0;
    border-radius: 0;
  }

  .image-row-item img.zoomable {
    cursor: zoom-in;
  }
</style>
